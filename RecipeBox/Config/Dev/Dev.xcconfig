//
//  Dev.xcconfig
//  iOSAppTemplate
//
//

// Configuration settings file format documentation can be found at:
// https://developer.apple.com/documentation/xcode/adding-a-build-configuration-file-to-your-project

// App Configuration
BUNDLE_ID = com.konotori.recipebox.dev
APP_NAME = RecipeBox-Dev

// Selects AppEnvironment.development at compile time (see AppEnvironment.swift).
// Flows into the target via `SWIFT_ACTIVE_COMPILATION_CONDITIONS = "DEBUG $(inherited)"`.
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEV

// Compile-time diagnostics (Dev only): warn on slow-to-compile code.
// Tune the millisecond thresholds as the codebase grows (e.g. 500 to reduce noise).
OTHER_SWIFT_FLAGS = -Xfrontend -warn-long-function-bodies=150 -Xfrontend -warn-long-expression-type-checking=150
